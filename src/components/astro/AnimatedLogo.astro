---
const { size = 72 } = Astro.props;
---
<div class="logo" role="img" aria-label="Ship's wheel" style={`--size:${size}px`}></div>

<style>
  .logo {
    width: var(--size);
    height: var(--size);
    background: var(--c-gold);
    -webkit-mask: url("/ship-wheel.svg") center / contain no-repeat;
    mask: url("/ship-wheel.svg") center / contain no-repeat;
    animation: logo-spin 9s linear infinite;
    filter: drop-shadow(2px 2px 0 rgba(0, 0, 0, 0.45));
  }
  @keyframes logo-spin {
    to {
      transform: rotate(360deg);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .logo {
      animation: none;
    }
  }
</style>
